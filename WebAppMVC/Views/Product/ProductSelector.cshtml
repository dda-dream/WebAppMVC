@using WebAppMVC_Models
@model List<ProductModel>

<p> *Product Selector* </p>
<p>Поиск продуктов по мере набора их в строке поиска - 1</p>


<input type="text" id="productSearch" placeholder="Вводите название продукта." />
<br />
<br />
<br />
<div id="ListProducts">
</div>

